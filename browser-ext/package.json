{
    "name": "authentik-browser-ext",
    "version": "0.40.6",
    "description": "Authentik Application Launcher Chrome Extension",
    "scripts": {
        "build": "rollup -c",
        "lint": "eslint --fix .",
        "lint-check": "eslint --max-warnings 0 .",
        "prettier": "prettier --cache --write -u .",
        "prettier-check": "prettier --cache --check -u .",
        "type-check": "tsc --noEmit -p .",
        "watch": "rollup -c -w"
    },
    "type": "module",
    "devDependencies": {
        "@codecov/rollup-plugin": "^2.0.1",
        "@goauthentik/api": "^2026.2.2",
        "@goauthentik/eslint-config": "^1.3.0",
        "@goauthentik/prettier-config": "^3.5.0",
        "@goauthentik/tsconfig": "^1.0.9",
        "@rollup/plugin-commonjs": "^29.0.2",
        "@rollup/plugin-node-resolve": "^16.0.3",
        "@rollup/plugin-typescript": "^12.3.0",
        "@sentry/browser": "^10.51.0",
        "@types/chrome": "^0.1.40",
        "fuse.js": "^7.3.0",
        "lit": "^3.3.2",
        "rollup": "^4.60.3",
        "tslib": "^2.8.1",
        "typescript": "^5.9.3"
    },
    "engines": {
        "node": ">=24"
    },
    "prettier": "@goauthentik/prettier-config"
}
