{
    "name": "authentik-browser-ext",
    "version": "0.44.3",
    "description": "Authentik Application Launcher Chrome Extension",
    "scripts": {
        "build": "rollup -c",
        "lint": "eslint --fix .",
        "lint-check": "eslint --max-warnings 0 .",
        "prettier": "prettier --cache --write -u .",
        "prettier-check": "prettier --cache --check -u .",
        "type-check": "tsc --noEmit -p .",
        "watch": "rollup -c -w"
    },
    "type": "module",
    "devDependencies": {
        "@codecov/rollup-plugin": "^2.0.1",
        "@goauthentik/api": "^2026.5.4",
        "@goauthentik/eslint-config": "^2.0.3",
        "@goauthentik/prettier-config": "^3.5.0",
        "@goauthentik/tsconfig": "^2.0.0",
        "@rollup/plugin-commonjs": "^29.0.3",
        "@rollup/plugin-node-resolve": "^16.0.3",
        "@rollup/plugin-typescript": "^12.3.0",
        "@sentry/browser": "^10.65.0",
        "@types/chrome": "^0.2.0",
        "eslint": "^9.39.3",
        "fuse.js": "^7.4.2",
        "lit": "^3.3.3",
        "prettier": "^3.9.5",
        "prettier-plugin-packagejson": "^3.0.2",
        "rollup": "^4.62.2",
        "tslib": "^2.8.1",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.63.0"
    },
    "engines": {
        "node": ">=24"
    },
    "prettier": "@goauthentik/prettier-config"
}
