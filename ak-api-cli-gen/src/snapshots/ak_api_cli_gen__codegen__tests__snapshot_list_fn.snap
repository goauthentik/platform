#[derive(Debug, Clone, clap::Subcommand)]
pub enum ApiCommand {
    ///Core API
    Core(Box<core::CoreArgs>),
}
impl ApiCommand {
    pub async fn execute(
        &self,
        config: &authentik_client::apis::configuration::Configuration,
    ) -> eyre::Result<()> {
        match self {
            ApiCommand::Core(args) => args.command.execute(config).await,
        }
    }
}
pub const API_MODULES: &[&str] = &["core"];
pub const API_FUNCTION_COUNT: usize = 1usize;
pub mod core {
    include!(concat!(env!("OUT_DIR"), "/", "api_commands_core.rs"));
}

